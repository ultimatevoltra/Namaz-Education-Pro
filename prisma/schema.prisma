generator client {
  provider = "prisma-client-js"
}

// Default provider is SQLite (zero setup).
// For production, set DATABASE_URL to a postgresql:// connection string
// and change provider to "postgresql" below.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isActive      Boolean   @default(true)
  accounts         Account[]
  sessions         Session[]
  salahProgress    SalahProgress[]
  salahMistakes    SalahMistake[]
  dailyStats       DailyStats[]
  userSettings     UserSettings?
  syncQueue        SyncQueue[]
  @@index([email])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verificationtokens")
}

model SalahProgress {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  salahType     String
  completedAt   DateTime  @default(now())
  duration      Int       @default(0)
  mistakes      String    @default("[]")
  score         Int       @default(100)
  feedback      String?
  isOfflineSync Boolean   @default(false)
  syncedAt      DateTime?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  salahMistakes SalahMistake[]
  @@index([userId])
  @@index([completedAt])
  @@index([salahType])
  @@map("salah_progress")
}

model SalahMistake {
  id              String   @id @default(cuid())
  salahProgressId String   @map("salah_progress_id")
  userId          String   @map("user_id")
  mistakeType     String
  severity        String   @default("medium")
  description     String?
  correction      String?
  detectedAt      DateTime @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  salahProgress SalahProgress @relation(fields: [salahProgressId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([salahProgressId])
  @@index([mistakeType])
  @@map("salah_mistakes")
}

model DailyStats {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  date             DateTime
  totalPrayers     Int      @default(0)
  completedPrayers Int      @default(0)
  averageScore     Float    @default(0)
  totalDuration    Int      @default(0)
  mistakeCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_stats")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  language             String   @default("en")
  notificationsEnabled Boolean  @default(true)
  theme                String   @default("light")
  timezone             String   @default("UTC")
  soundEnabled         Boolean  @default(true)
  vibrationEnabled     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("user_settings")
}

model SyncQueue {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  action    String
  table     String
  data      String
  synced    Boolean   @default(false)
  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([synced])
  @@map("sync_queue")
}
